<div class="comment-card p-3 h-100 mb-3">
    <div class="comment-header d-flex justify-content-between p-3 rounded-top">
        <div>
            <strong class="fs-5">{{ comment.user.username }}</strong>
            <div class="text-muted small">{{ comment.createdAt|date('M d, Y \\a\\t H:i') }}</div>
        </div>
        {% if app.user and comment.user.id == app.user.id %}
            <div class="comment-actions">
                <a href="{{ path('comment_edit', { id: comment.id }) }}" class="btn btn-sm btn-outline-primary mb-1">Edit</a>
                <form method="post" action="{{ path('comment_delete', { id: comment.id }) }}" style="display:inline-block;" onsubmit="return confirm('Are you sure you want to delete this comment?');">
                    <input type="hidden" name="_token" value="{{ csrf_token('delete-comment' ~ comment.id) }}">
                    <button class="btn btn-sm btn-danger">Delete</button>
                </form>
            </div>
        {% endif %}
    </div>
    <div class="p-3">
        <p class="mb-0">{{ comment.content }}</p>
    </div>
</div>

