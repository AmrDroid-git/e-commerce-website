{% extends 'base.html.twig' %}

{% block title %}Confirm order - ScriptSphere{% endblock %}

{% block body %}
    <section class="page-shell">
        <div class="page-hero-card mb-4 text-center">
            <span class="page-eyebrow"><i class="fas fa-shield-alt"></i> Secure demo checkout</span>
            <h1 class="page-title">Confirm your order</h1>
            <p class="page-subtitle mx-auto mb-0">
                This direct payment mode is a safe demo flow. It does not collect or store real card details.
            </p>
        </div>

        <div class="row justify-content-center">
            <div class="col-lg-8">
                <div class="clean-card p-4 p-md-5">
                    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
                        <div>
                            <h2 class="h4 mb-1">Order preview</h2>
                            <p class="text-muted mb-0">Customer: {{ commande.user.username }}</p>
                        </div>
                        <span class="badge text-bg-primary rounded-pill px-3 py-2">{{ panier.products|length }} item{{ panier.products|length == 1 ? '' : 's' }}</span>
                    </div>

                    <div class="list-group list-group-flush mb-4">
                        {% for product in panier.products %}
                            <div class="list-group-item px-0 d-flex justify-content-between align-items-center">
                                <div>
                                    <div class="fw-semibold">{{ product.name }}</div>
                                    <small class="text-muted">{{ product.category }}</small>
                                </div>
                                <strong>{{ product.price|number_format(2, '.', ' ') }} €</strong>
                            </div>
                        {% endfor %}
                    </div>

                    <div class="bg-light rounded-4 p-4 mb-4">
                        <div class="d-flex justify-content-between align-items-center fs-5 fw-bold">
                            <span>Total</span>
                            <span>{{ totalPrice|number_format(2, '.', ' ') }} €</span>
                        </div>
                    </div>

                    <form action="{{ path('payment_process') }}" method="POST" class="d-grid gap-3">
                        <input type="hidden" name="_token" value="{{ csrf_token('direct_payment') }}">
                        <button type="submit" class="btn btn-brand btn-lg">
                            <i class="fas fa-check-circle me-2"></i>Confirm demo payment
                        </button>
                        <a href="{{ path('app_checkout') }}" class="btn btn-outline-secondary">
                            <i class="fas fa-arrow-left me-2"></i>Back to checkout
                        </a>
                    </form>
                </div>
            </div>
        </div>
    </section>
{% endblock %}

{% block developpers %}{% endblock %}

