{% extends 'base.html.twig' %}

{% block title %}Products - ScriptSphere{% endblock %}

{% block body %}
    <section class="page-shell">
        <div class="page-hero-card mb-4">
            <span class="page-eyebrow"><i class="fas fa-sparkles"></i> Digital marketplace</span>
            <h1 class="page-title">Find your next web asset</h1>
            <p class="page-subtitle mb-0">
                Browse ready-to-use templates, bundles, bots and UI kits. Use search and filters to find exactly what you need.
            </p>
        </div>

        <div class="filter-card p-4 mb-4">
            <form method="get" action="{{ path('product') }}" class="row g-3 align-items-end">
                <div class="col-lg-5">
                    <label class="form-label fw-semibold" for="searchInput">Search</label>
                    <div class="input-group">
                        <span class="input-group-text bg-light border-0"><i class="fas fa-search text-muted"></i></span>
                        <input id="searchInput" type="text" name="search" value="{{ currentSearch }}" class="form-control border-start-0" placeholder="Product name, category or description...">
                    </div>
                </div>

                <div class="col-md-4 col-lg-3">
                    <label class="form-label fw-semibold" for="categorySelect">Category</label>
                    <select id="categorySelect" name="category" class="form-select">
                        <option value="0" {{ currentCategory == 0 ? 'selected' : '' }}>All categories</option>
                        {% for cat in categories %}
                            <option value="{{ cat.id }}" {{ cat.id == currentCategory ? 'selected' : '' }}>{{ cat.name }}</option>
                        {% endfor %}
                    </select>
                </div>

                <div class="col-md-4 col-lg-2">
                    <label class="form-label fw-semibold" for="sortSelect">Sort</label>
                    <select id="sortSelect" name="sort" class="form-select">
                        <option value="name" {{ currentSort == 'name' ? 'selected' : '' }}>Name</option>
                        <option value="rating" {{ currentSort == 'rating' ? 'selected' : '' }}>Top rated</option>
                        <option value="newest" {{ currentSort == 'newest' ? 'selected' : '' }}>Newest</option>
                        <option value="price_asc" {{ currentSort == 'price_asc' ? 'selected' : '' }}>Price ↑</option>
                        <option value="price_desc" {{ currentSort == 'price_desc' ? 'selected' : '' }}>Price ↓</option>
                    </select>
                </div>

                <div class="col-md-4 col-lg-2 d-grid">
                    <button type="submit" class="btn btn-brand">
                        <i class="fas fa-filter me-1"></i>Apply
                    </button>
                </div>
            </form>
        </div>

        <div class="d-flex align-items-center justify-content-between mb-4 gap-3 flex-wrap">
            <div>
                <h2 class="h4 mb-1">Available products</h2>
                <p class="text-muted mb-0">{{ productsWithRating|length }} result{{ productsWithRating|length == 1 ? '' : 's' }}</p>
            </div>

            {% if is_granted('ROLE_ADMIN') %}
                <a href="{{ path('admin_product_new') }}" class="btn btn-brand">
                    <i class="fas fa-plus-circle me-2"></i>New Product
                </a>
            {% endif %}
        </div>

        {% include 'component/products.html.twig' %}
    </section>
{% endblock %}

{% block developpers %}{% endblock %}

