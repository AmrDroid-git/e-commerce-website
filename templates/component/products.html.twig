<div class="product-grid">
    {% for entry in productsWithRating %}
        {% set product = entry.product %}
        {% set rating = entry.rating %}
        {% set isFav = (app.user and is_granted('ROLE_USER')) ? app.user.getFavorites().contains(product) : false %}

        <article class="product-tile d-flex flex-column">
            <a href="{{ path('product_show', { id: product.id }) }}" class="product-media d-block text-decoration-none">
                {% if product.imageUrl %}
                    <img src="{{ asset('uploads/products/' ~ product.imageUrl) }}" alt="{{ product.name }}">
                {% else %}
                    <div class="d-flex align-items-center justify-content-center h-100 text-muted">
                        <i class="fas fa-image fa-3x"></i>
                    </div>
                {% endif %}
                <span class="product-badge">{{ product.category }}</span>
            </a>

            <div class="p-4 d-flex flex-column flex-grow-1">
                <div class="d-flex justify-content-between gap-3 align-items-start mb-2">
                    <h3 class="h5 fw-bold mb-0">{{ product.name }}</h3>
                    <span class="price-text text-nowrap">{{ product.price|number_format(2, '.', ' ') }} €</span>
                </div>

                <p class="text-muted small flex-grow-1 mb-3">
                    {{ product.description ? product.description|striptags|slice(0, 110) ~ (product.description|length > 110 ? '...' : '') : 'No description available yet.' }}
                </p>

                <div class="d-flex justify-content-between align-items-center mb-3 gap-2">
                    <div class="rating-stars">
                        {% if rating is not null %}
                            {% for i in 1..5 %}
                                {% if i <= rating %}
                                    <i class="fas fa-star"></i>
                                {% elseif i - rating <= 0.5 %}
                                    <i class="fas fa-star-half-alt"></i>
                                {% else %}
                                    <i class="far fa-star"></i>
                                {% endif %}
                            {% endfor %}
                            <span class="text-muted small ms-1">{{ rating }} ({{ entry.ratingCount }})</span>
                        {% else %}
                            <span class="text-muted small">No ratings yet</span>
                        {% endif %}
                    </div>

                    <span class="stock-badge {{ product.quantity > 0 ? '' : 'out' }}">
                        <i class="fas {{ product.quantity > 0 ? 'fa-check' : 'fa-ban' }}"></i>
                        {{ product.quantity > 0 ? product.quantity ~ ' left' : 'Out' }}
                    </span>
                </div>

                <div class="d-flex gap-2 mt-auto">
                    <a href="{{ path('product_show', { id: product.id }) }}" class="btn btn-outline-primary flex-fill">
                        <i class="fas fa-search me-1"></i>View
                    </a>

                    {% if is_granted('ROLE_USER') %}
                        {% if product.quantity > 0 %}
                            <form action="{{ path('app_panier_add', { user: app.user.id }) }}" method="post" class="flex-fill">
                                <input type="hidden" name="product_id" value="{{ product.id }}">
                                <input type="hidden" name="_token" value="{{ csrf_token('cart_add_' ~ product.id) }}">
                                <button class="btn btn-brand w-100" type="submit">
                                    <i class="fas fa-cart-plus me-1"></i>Add
                                </button>
                            </form>
                        {% else %}
                            <button class="btn btn-secondary flex-fill" disabled>Unavailable</button>
                        {% endif %}
                    {% else %}
                        <a href="{{ path('app_login') }}" class="btn btn-brand flex-fill">
                            <i class="fas fa-cart-plus me-1"></i>Add
                        </a>
                    {% endif %}

                    {% if is_granted('ROLE_USER') %}
                        <button type="button"
                                class="favorite-btn btn {{ isFav ? 'btn-danger' : 'btn-outline-danger' }}"
                                aria-label="{{ isFav ? 'Remove from favorites' : 'Add to favorites' }}"
                                data-product-id="{{ product.id }}"
                                data-action-url="{{ isFav ? path('favorite_remove', { id: product.id }) : path('favorite_add', { id: product.id }) }}"
                                data-csrf-token="{{ isFav ? csrf_token('remove' ~ product.id) : csrf_token('add' ~ product.id) }}"
                                data-add-url="{{ path('favorite_add', { id: product.id }) }}"
                                data-remove-url="{{ path('favorite_remove', { id: product.id }) }}"
                                data-add-token="{{ csrf_token('add' ~ product.id) }}"
                                data-remove-token="{{ csrf_token('remove' ~ product.id) }}">
                            <i class="{{ isFav ? 'fas' : 'far' }} fa-heart"></i>
                        </button>
                    {% else %}
                        <a href="{{ path('app_login') }}" class="btn btn-outline-danger" aria-label="Login to favorite">
                            <i class="far fa-heart"></i>
                        </a>
                    {% endif %}
                </div>

                {% if is_granted('ROLE_ADMIN') %}
                    <div class="d-flex gap-2 mt-3 pt-3 border-top">
                        <a href="{{ path('admin_product_edit', {'id': product.id}) }}" class="btn btn-sm btn-outline-primary flex-fill">
                            <i class="fas fa-pencil-alt me-1"></i>Edit
                        </a>
                        <form action="{{ path('admin_product_delete', {'id': product.id}) }}" method="post" class="flex-fill" onsubmit="return confirm('Remove this product from the public catalog?');">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ product.id) }}">
                            <button class="btn btn-sm btn-outline-danger w-100" type="submit">
                                <i class="fas fa-trash me-1"></i>Delete
                            </button>
                        </form>
                    </div>
                {% endif %}
            </div>
        </article>
    {% else %}
        <div class="clean-card p-5 text-center grid-column-full">
            <i class="fas fa-box-open fa-3x text-muted mb-3"></i>
            <h3 class="h5">No products found</h3>
            <p class="text-muted mb-0">Try changing the search or category filter.</p>
        </div>
    {% endfor %}
</div>

