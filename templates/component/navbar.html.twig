<header class="custom-navbar">
    <a href="{{ path('app_home') }}" class="navbar-brand" aria-label="ScriptSphere home">
        <span class="brand-icon"><i class="fas fa-cube"></i></span>
        <span>ScriptSphere</span>
    </a>

    <button class="mobile-menu-btn" id="mobileMenuBtn" type="button" aria-label="Open menu" aria-controls="navLinks" aria-expanded="false">
        <i class="fas fa-bars"></i>
    </button>

    <ul class="nav-links" id="navLinks">
        <li>
            <a href="{{ path('product') }}" class="nav-link {% if app.request.get('_route') starts with 'product' %}active{% endif %}">
                <i class="fas fa-box-open"></i><span>Products</span>
            </a>
        </li>

        {% if is_granted('ROLE_USER') %}
            <li>
                <a href="{{ path('app_dashboard') }}" class="nav-link {% if app.request.get('_route') == 'app_dashboard' %}active{% endif %}">
                    <i class="fas fa-chart-line"></i><span>Dashboard</span>
                </a>
            </li>
            <li>
                <a href="{{ path('app_commandes') }}" class="nav-link {% if app.request.get('_route') == 'app_commandes' %}active{% endif %}">
                    <i class="fas fa-receipt"></i><span>Purchases</span>
                </a>
            </li>
            <li>
                <a href="{{ path('favorite_list') }}" class="nav-link {% if app.request.get('_route') == 'favorite_list' %}active{% endif %}">
                    <i class="fas fa-heart"></i><span>Favorites</span>
                </a>
            </li>
            <li>
                <a href="{{ path('app_panier', {'user': app.user.id}) }}" class="nav-link {% if app.request.get('_route') == 'app_panier' %}active{% endif %}">
                    <i class="fas fa-shopping-bag"></i><span>Cart</span>
                    {% if app.user.panier and app.user.panier.products|length > 0 %}
                        <span class="cart-pill">{{ app.user.panier.products|length }}</span>
                    {% endif %}
                </a>
            </li>
        {% endif %}

        {% if is_granted('ROLE_ADMIN') %}
            <li>
                <a href="{{ path('app_admin_dashboard') }}" class="nav-link {% if app.request.get('_route') == 'app_admin_dashboard' %}active{% endif %}">
                    <i class="fas fa-gauge-high"></i><span>Admin</span>
                </a>
            </li>
            <li>
                <a href="{{ path('app_manage_users') }}" class="nav-link {% if app.request.get('_route') == 'app_manage_users' %}active{% endif %}">
                    <i class="fas fa-user-cog"></i><span>Users</span>
                </a>
            </li>
        {% endif %}
    </ul>

    <div class="navbar-actions">
        {% if is_granted('ROLE_USER') or is_granted('ROLE_ADMIN') %}
            <a href="{{ path('app_logout') }}" class="btn btn-outline-light btn-sm">
                <i class="fas fa-sign-out-alt me-1"></i>Logout
            </a>
        {% else %}
            <a href="{{ path('app_registeration') }}" class="btn btn-outline-light btn-sm">
                <i class="fas fa-user-plus me-1"></i>Register
            </a>
            <a href="{{ path('app_login') }}" class="btn btn-light btn-sm text-primary-emphasis">
                <i class="fas fa-sign-in-alt me-1"></i>Login
            </a>
        {% endif %}
    </div>
</header>

